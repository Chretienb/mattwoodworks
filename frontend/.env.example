# Copy to .env and fill in (never commit .env)

# Dev: leave VITE_API_URL unset so /api and /health go through Vite → 127.0.0.1:8080
# (npm run dev:api or npm run dev:api:rust must be running for forms + admin).

# Optional: your own backend URL in production (omit in dev → Vite proxy / same origin)
# VITE_API_URL=https://api.example.com

# Supabase (paste anon key from Dashboard → API; never commit real values here)
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key
