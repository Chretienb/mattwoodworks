# Password-only staff login: must match the Supabase Auth user email (or local dev user).
# MHW_ADMIN_EMAIL=your-admin@example.com

# Optional: enable Supabase (all four required). If any is missing, the API uses local files/jsonl.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Dashboard → Project Settings → API → JWT Secret (HS256). Server only; never put in Vite.
SUPABASE_JWT_SECRET=

# MHW_BIND=127.0.0.1:8080
# MHW_ADMIN_PASSWORD=devpassword
